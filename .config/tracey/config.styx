specs (
    {
        name hark
        include (spec/**/*.md)
        impls (
            {
                name app
                include (
                    bee/**/*.swift
                    bee-input/**/*.swift
                    hark/**/*.swift
                    HarkInput/**/*.swift
                    qwen3-asr-rs/**/*.rs
                )
                exclude (
                    qwen3-asr-rs/target/**
                    qwen3-asr-rs/vendor/**
                )
            }
        )
    }
)
